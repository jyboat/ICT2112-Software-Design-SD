@{
    ViewData["Title"] = "Side Effects List";
    var sideEffects = ViewData["SideEffects"] as List<dynamic>;
}

<h2>@ViewData["Title"]</h2>

@if (sideEffects != null && sideEffects.Count > 0)
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sideEffect in sideEffects)
            {
                <tr>
                    <td>@sideEffect.Name</td>
                    <td>@sideEffect.Description</td>
                    <td>@sideEffect.Date</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No side effects reported yet.</p>
}
