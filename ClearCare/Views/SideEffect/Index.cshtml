@model List<ClearCare.Models.SideEffectModel>

<h2>Side Effects List</h2>

@if (Model != null && Model.Count > 0)
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sideEffect in Model)
            {
                <tr>
                    <td>@sideEffect.Name</td>
                    <td>@sideEffect.Description</td>
                    <td>@sideEffect.Date</td> <!-- Ensure this matches the property name -->
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No side effects reported yet.</p>
}
