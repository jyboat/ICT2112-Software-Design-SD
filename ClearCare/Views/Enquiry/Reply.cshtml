@model ReplyToEnquiryViewModel

@{
    ViewData["Title"] = "Reply to Enquiry";
}

<div class="container py-4">
    <!-- Notification Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="bi bi-reply-fill text-primary me-2"></i>Reply to Enquiry
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
    </div>

    <div class="row g-4">
        <!-- Enquiry Details Card -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light">
                    <h4 class="card-title mb-0">
                        <i class="bi bi-envelope me-2"></i>Enquiry Details
                    </h4>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted">ID:</dt>
                        <dd class="col-sm-8 mb-2">
                            <code>@Model.Enquiry.FirestoreId</code>
                        </dd>
                        
                        <dt class="col-sm-4 text-muted">From:</dt>
                        <dd class="col-sm-8 mb-2">
                            <strong>@Model.Enquiry.Name</strong>
                        </dd>
                        
                        <dt class="col-sm-4 text-muted">Email:</dt>
                        <dd class="col-sm-8 mb-2">
                            <a href="mailto:@Model.Enquiry.Email">@Model.Enquiry.Email</a>
                        </dd>
                        
                        <dt class="col-sm-4 text-muted">Message:</dt>
                        <dd class="col-sm-8">
                            <div class="p-3 bg-light rounded">
                                @Model.Enquiry.Message
                            </div>
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
        
        <!-- Reply Form Card -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light">
                    <h4 class="card-title mb-0">
                        <i class="bi bi-pencil-square me-2"></i>Your Reply
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="SendReply" method="post">
                        <input type="hidden" name="enquiryId" value="@Model.Enquiry.FirestoreId" />
                        <input type="hidden" name="recipientName" value="@Model.Enquiry.Name" />
                        <input type="hidden" name="recipientEmail" value="@Model.Enquiry.Email" />
                        <input type="hidden" name="originalMessage" value="@Model.Enquiry.Message" />
                        <input type="hidden" name="userUUID" value="@Model.Enquiry.UserUUID" />
                        
                        <div class="mb-3">
                            <label for="replySubject" class="form-label">Subject</label>
                            <input type="text" class="form-control" id="replySubject" name="subject" 
                                   placeholder="Enter subject line" required>
                        </div>
                        
                        <div class="mb-3">
                            <label for="replyMessage" class="form-label">Reply Message</label>
                            <textarea class="form-control" id="replyMessage" name="message" 
                                      rows="6" placeholder="Type your reply here..." required></textarea>
                        </div>
                        
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-send-fill me-2"></i>Send Reply
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Previous Replies Section -->
    <div class="mt-5">
        <h3 class="mb-3">
            <i class="bi bi-chat-left-text me-2"></i>Previous Replies
        </h3>

        @if (Model.Replies != null && Model.Replies.Any())
        {
            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush">
                        @foreach (var reply in Model.Replies.OrderBy(r => r.CreatedAt))
                        {
                            <li class="list-group-item p-4">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h5 class="mb-0">@reply.Subject</h5>
                                    <span class="badge bg-secondary">
                                        @reply.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                                    </span>
                                </div>
                                <p class="mb-0">@reply.Message</p>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>No replies have been sent yet.
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Auto-dismiss alerts after 5 seconds
        setTimeout(function() {
            $('.alert').alert('close');
        }, 5000);
    </script>
}
