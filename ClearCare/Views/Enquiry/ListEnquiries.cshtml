@model List<ClearCare.Models.Enquiry>

@{
    ViewData["Title"] = "Enquiries Dashboard";
}

<div class="container py-4">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">
                <i class="bi bi-envelope-fill text-primary me-2"></i>Enquiries Dashboard
            </h2>
            <p class="text-muted mb-0">Manage and respond to customer enquiries</p>
        </div>
        
        <!-- Optional: Add a search or filter form here -->
        <div class="card bg-primary text-white shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Total Enquiries</h5>
                    <h3 class="mb-0">@Model.Count</h3>
                </div>
            </div>
    </div>

    <!-- Stats Cards (Optional) -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
           
        </div>
        
        
    </div>

    <!-- Enquiries Table -->
    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h4 class="card-title mb-0">
                <i class="bi bi-list-ul me-2"></i>All Enquiries
            </h4>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" class="ps-4">Name</th>
                            <th scope="col">Email</th>
                            <th scope="col" style="width: 30%;">Message</th>
                            <th scope="col" class="text-center">User ID</th>
                            <th scope="col" class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var enquiry in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold">@enquiry.Name</div>
                                        <small class="text-muted">ID: @enquiry.Id.Substring(0, Math.Min(8, enquiry.Id.Length))...</small>
                                    </td>
                                    <td>
                                        <a href="mailto:@enquiry.Email">@enquiry.Email</a>
                                    </td>
                                    <td>
                                        <div class="text-truncate" style="max-width: 300px;">
                                            @enquiry.Message
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-secondary">
                                            @(string.IsNullOrEmpty(enquiry.UserUUID) ? "N/A" : enquiry.UserUUID.Substring(0, Math.Min(8, enquiry.UserUUID.Length)))
                                        </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group">
                                            <a href="@Url.Action("Reply", "Enquiry", new { id = enquiry.FirestoreId })" 
                                               class="btn btn-sm btn-primary">
                                                <i class="bi bi-reply-fill me-1"></i>Reply
                                            </a>
                                            <button type="button" class="btn btn-sm btn-primary dropdown-toggle dropdown-toggle-split" 
                                                    data-bs-toggle="dropdown" aria-expanded="false">
                                                <span class="visually-hidden">Toggle Dropdown</span>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <a class="dropdown-item" href="#">
                                                        <i class="bi bi-eye me-2"></i>View Details
                                                    </a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item" href="#">
                                                        <i class="bi bi-archive me-2"></i>Archive
                                                    </a>
                                                </li>
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <a class="dropdown-item text-danger" href="#">
                                                        <i class="bi bi-trash me-2"></i>Delete
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4">
                                    <div class="text-muted">
                                        <i class="bi bi-inbox-fill fs-1 d-block mb-2"></i>
                                        <p>No enquiries found</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-light">
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center mb-0">
                    <li class="page-item disabled">
                        <a class="page-link" href="#" tabindex="-1" aria-disabled="true">Previous</a>
                    </li>
                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                    <li class="page-item"><a class="page-link" href="#">2</a></li>
                    <li class="page-item"><a class="page-link" href="#">3</a></li>
                    <li class="page-item">
                        <a class="page-link" href="#">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Enable tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        });
        
        // Optional: Add table row hover effect
        document.querySelectorAll('tbody tr').forEach(row => {
            row.addEventListener('click', function(e) {
                if (!e.target.closest('a, button')) {
                    const id = this.querySelector('td:first-child small').textContent.split('ID: ')[1].replace('...', '');
                    window.location.href = '@Url.Action("Reply", "Enquiry")/' + id;
                }
            });
        });
    </script>
}
